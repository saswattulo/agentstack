# ----- Environment -----
# dev | prod
APP_ENV=dev
LOG_LEVEL=INFO
APP_HOST=0.0.0.0
APP_PORT=8000

# ----- Auth -----
# A dev API key for local use. Tied to the dev user (DEV_USER_EMAIL).
DEV_API_KEY=dev-local-key-change-me
DEV_USER_EMAIL=dev@agentstack.local

# JWT settings. CHANGE jwt_secret_key in prod (use `openssl rand -hex 32`).
JWT_SECRET_KEY=change-me-in-prod-please-this-is-not-safe
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=1440
JWT_ISSUER=agentstack

# ----- Database -----
POSTGRES_USER=agentstack
POSTGRES_PASSWORD=agentstack
POSTGRES_DB=agentstack
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Async SQLAlchemy URL — composed automatically if left blank
DATABASE_URL=

# ----- Redis -----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=

# ----- Qdrant -----
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=

# ----- Celery -----
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# ----- LLM: Groq -----
GROQ_API_KEY=
GROQ_CHAT_MODEL=qwen/qwen3-32b
GROQ_FALLBACK_MODEL=llama-3.3-70b-versatile

# ----- Embeddings (local, sentence-transformers) -----
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384
EMBEDDING_DEVICE=cpu

# ----- Reranker (Week 2 / stretch) -----
RERANKER_MODEL=BAAI/bge-reranker-base
RERANKER_ENABLED=false

# ----- Web search (Week 2) -----
TAVILY_API_KEY=

# ----- Tracing (Phoenix) -----
PHOENIX_COLLECTOR_ENDPOINT=http://phoenix:6006
PHOENIX_PROJECT_NAME=agentstack

# ----- Rate limiting -----
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_DAY=10000

# ----- Ingestion -----
CHUNK_SIZE=512
CHUNK_OVERLAP=64
INGEST_MAX_FILE_MB=50

# ----- Caching -----
LLM_CACHE_ENABLED=true
SEMANTIC_CACHE_THRESHOLD=0.95
CACHE_TTL_SECONDS=86400
